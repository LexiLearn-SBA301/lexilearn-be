# Copy file này thành .env rồi điền giá trị thật. File .env sẽ KHÔNG bị commit.
# KHÔNG bao giờ để secret thật trong file .env.example này (nó được push lên GitHub).

# --- Database ---
DB_NAME=lexilearn
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6369
REDIS_PASSWORD=

# --- Mail (Gmail App Password để gửi OTP) ---
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# --- JWT (production BẮT BUỘC đổi, >= 32 ký tự) ---
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret